APP_NAME="SCAK Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scak_platform
DB_USERNAME=root
DB_PASSWORD=

WP_DB_HOST=127.0.0.1
WP_DB_PORT=3306
WP_DB_DATABASE=
WP_DB_USERNAME=
WP_DB_PASSWORD=
WP_DB_PREFIX=wp_
WP_UPLOADS_PATH=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
PRODUCT_FILESYSTEM_DRIVER=local
PRODUCT_STORAGE_DISK=products
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

OTP_WHATSAPP_ENDPOINT=
OTP_TIMEOUT_SECONDS=15
OTP_EXPIRES_IN_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_DEFAULT_COUNTRY_CODE=+91
OTP_TEST_MODE=true

FCM_SERVER_KEY=
FCM_SENDER_ID=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
